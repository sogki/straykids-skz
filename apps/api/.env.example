# Player OAuth API — local bootstrap (pick one approach).
#
# Easiest: copy your Supabase URL + service role from apps/bot/.env into this file,
# or leave this file empty if bot/.env already has them (dev:api loads bot/.env automatically).
#
# After the first connect, Discord OAuth secrets and site_url are read from skz_bot_settings
# (Admin → Discord bot → Credentials).

# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Or explicit bootstrap aliases (same values):
# SKZ_BOOTSTRAP_SUPABASE_URL=https://xxx.supabase.co
# SKZ_BOOTSTRAP_SUPABASE_SERVICE_ROLE_KEY=

# Local dev overrides (optional — DB site_url wins when set in admin):
# SITE_URL=http://localhost:5173

API_PORT=8787
