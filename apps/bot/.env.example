# Copy to .env and fill in. Never commit .env.

# Required: from the Discord Developer Portal (Bot tab)
DISCORD_TOKEN=

# Required: your application's Client ID (General Information tab)
DISCORD_CLIENT_ID=

# Optional: if set, slash commands register to this guild only (instant updates,
# great for development). Leave empty to register globally (takes up to 1h to
# propagate on first deploy).
DISCORD_GUILD_ID=

# Optional: connect to the same Supabase project as the web app for shared
# leaderboards. Use the service-role key on the bot (server-side only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
