# Copy to .env and fill in. Never commit .env.
#
# These are bootstrap credentials only — they're the minimum needed for
# the bot to reach Discord + the database. Everything else (guild ID,
# channel IDs, reaction-role mappings, etc.) is configured in the admin
# panel and lives in the skz_bot_settings / skz_bot_reaction_roles tables.

# Required: from the Discord Developer Portal (Bot tab)
DISCORD_TOKEN=

# Required: your application's Client ID (General Information tab)
DISCORD_CLIENT_ID=

# Required: same Supabase project as the web app. Use the SERVICE ROLE
# key (Project Settings → API → service_role). Never expose this to the
# browser — it bypasses RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: if set, slash commands register to this guild only (instant
# updates, great for development). Leave empty to register globally
# (takes up to 1h to propagate on first deploy).
DISCORD_GUILD_ID=
