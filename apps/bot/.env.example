# Local dev bootstrap. On Railway, set the same two vars in the service dashboard.
#
# Discord token + client ID live in skz_bot_settings (Admin → Credentials).
# Supabase URL + service role can also be stored there, but the process still
# needs SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY in env to connect the first time.
#
# After the first connect, DB values in skz_bot_settings win on /reload.

# Optional one-time bootstrap to reach Supabase before DB credentials exist
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: instant slash-command updates in a dev guild (guild_id in DB is preferred)
# DISCORD_GUILD_ID=
