# Copy to .env ONLY for one-time bootstrap (optional).
#
# All secrets (Discord token, Supabase service role) should live in
# skz_bot_settings and be managed via Admin → Discord bot → Credentials.
#
# If both bootstrap vars below AND the DB rows are set, the DB wins after
# the first successful connect.

# Optional one-time bootstrap to reach Supabase before DB credentials exist
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: instant slash-command updates in a dev guild (guild_id in DB is preferred)
# DISCORD_GUILD_ID=
