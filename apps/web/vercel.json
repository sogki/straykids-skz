{
  "functions": {
    "api/player/auth/**/*.ts": {
      "includeFiles": "node_modules/@skz/api/src/**"
    },
    "api/_lib/**/*.ts": {
      "includeFiles": "node_modules/@skz/api/src/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/jype-image/:path*",
      "destination": "https://d1al7qj7ydfbpt.cloudfront.net/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
