{
  "name": "skz-arcade",
  "private": true,
  "version": "1.0.0",
  "description": "SKZ Arcade monorepo — web app + Discord bot + shared game logic.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace=@skz/web",
    "dev:bot": "npm run dev --workspace=@skz/bot",
    "build": "turbo run build",
    "build:web": "npm run build --workspace=@skz/web",
    "build:bot": "npm run build --workspace=@skz/bot",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.7"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.0"
}
